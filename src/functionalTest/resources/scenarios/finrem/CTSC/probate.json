{
  "description": "finrem create ExamineDigitalCaseFinrem task",
  "enabled": true,
  "jurisdiction": "FINREM",
  "caseType": "GrantOfRepresentation",
  "options": {
    "taskRetrievalApi": "task-management-api"
  },
  "required": {
    "credentials": {
      "key": "systemupdate"
    },
    "ccd": [
      {
        "eventId": "applyforGrantPaperApplicationMan",
        "caseData": {
          "template": "minimal-finrem.json",
          "replacements": {
          }
        }
      }
    ]
  },
  "test": {
    "request": {
      "credentials": {
        "key": "caseworker"
      },
      "input": {
        "eventMessages": [
          {
            "destination": "RestEndpoint",
            "template": "minimal-ccd-event-message-finrem.json",
            "replacements": {
              "EventId": "handleEvidence",
              "NewStateId": "CasePrinted"
            }
          }
        ]
      }
    },
    "expectations": [
      {
        "credentials": {
          "key": "CTSC-Administrator"
        },
        "status": 200,
        "numberOfTasksAvailable": 1,
        "taskData": {
          "template": "minimal-task-response-finrem.json",
          "replacements": {
            "tasks": [
              {
                "test_meta_data": [
                  {
                    "key": "role_data_reference",
                    "value": "ExamineDigitalCaseFinrem"
                  }
                ],
                "type": "ExamineDigitalCaseFinrem",
                "name": "Examine Digital Case - Finrem",
                "minor_priority": 500,
                "major_priority": 5000,
                "description": "[Select For QA](/cases/case-details/${[CASE_REFERENCE]}/trigger/boSelectForQA)"
              }
            ]
          }
        },
        "roleData": [
          {
            "key": "ExamineDigitalCaseFinrem",
            "numberOfRolesAvailable": 1,
            "roles": [
              {
                "role_category": "CTSC",
                "role_name": "ctsc",
                "permissions": [ "Read", "Own", "Manage", "Complete", "Claim", "Unclaim" ],
                "authorisations": []
              }
            ]
          }
        ]
      }
    ]
  }
}
